else
  export NODE_PATH="/home/err/devel/orgs/riatzukiza/promethean/node_modules/.pnpm/clj-kondo@2023.12.15/node_modules/clj-kondo/bin/node_modules:/home/err/devel/orgs/riatzukiza/promethean/node_modules/.pnpm/clj-kondo@2023.12.15/node_modules/clj-kondo/node_modules:/home/err/devel/orgs/riatzukiza/promethean/node_modules/.pnpm/clj-kondo@2023.12.15/node_modules:/home/err/devel/orgs/riatzukiza/promethean/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../clj-kondo/bin/clj-kondo" "$@"
else
  exec node  "$basedir/../clj-kondo/bin/clj-kondo" "$@"
fi
